{
    "$schema": "./manifest.schema.json",
    "manifest_version": 4,
    "type": "extension",
    "name": "Scriptio",
    "slug": "scriptio",
    "description": "📄 自定义用户脚本加载器",
    "version": "1.4.6",
    "icon": "./icons/icon.svg",
    "thumb": "./icons/thumb.svg",
    "authors": [
        {
            "name": "PRO-2684",
            "link": "https://github.com/PRO-2684"
        }
    ],
    "repository": {
        "repo": "PRO-2684/Scriptio",
        "branch": "main",
        "release": {
            "tag": "v1.4.6",
            "file": "scriptio-release.zip"
        }
    },
    "store": {
        "repo": "PRO-2684/Scriptio",
        "branch": "main",
        "save_folder": "./scripts/"
    },
    "platform": ["win32", "linux", "darwin"],
    "injects": {
        "renderer": "./renderer.js",
        "main": "./main.cjs",
        "preload": "./preload.js"
    }
}
